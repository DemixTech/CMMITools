# Browser data and cache
.browser-data/

# Logs and generated output
html_logs/

# ==========================================
# Node.js / TypeScript Standard .gitignore
# ==========================================

# Dependencies
node_modules/
jspm_packages/

# Environment Variables (CRITICAL: Prevents leaking API keys and passwords)
.env
.env.local
.env.*

# Build Output (Compiled TypeScript/JavaScript code)
dist/
build/
out/
lib/
*.tsbuildinfo

# NPM / Yarn / PNPM Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Testing and Coverage
coverage/
.nyc_output/

# OS Generated Files (Mac/Windows clutter)
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE and Editor Folders
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ==========================================
# Project Specific (Your custom ignores)
# ==========================================
_delete/